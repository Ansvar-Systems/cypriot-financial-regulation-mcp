{
  "name": "@ansvar/cypriot-financial-regulation-mcp",
  "version": "0.1.0",
  "mcpName": "eu.ansvar/cypriot-financial-regulation-mcp",
  "description": "CySEC and CBC (Central Bank of Cyprus) financial regulation MCP server \u2014 directives, circulars, and prudential regulations",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cypriot-financial-regulation-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "server.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ansvar-Systems/cypriot-financial-regulation-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Ansvar-Systems/cypriot-financial-regulation-mcp/issues"
  },
  "homepage": "https://github.com/Ansvar-Systems/cypriot-financial-regulation-mcp#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "claude",
    "cysec",
    "cbc",
    "cypriot-financial-regulation",
    "compliance",
    "financial-services",
    "ansvar",
    "cyprus"
  ],
  "author": "Ansvar Systems AB <hello@ansvar.ai>",
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/http-server.ts",
    "start": "node dist/http-server.js",
    "seed": "npx tsx scripts/seed-sample.ts",
    "ingest": "npx tsx scripts/ingest-cysec.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit",
    "ingest:fetch": "tsx scripts/ingest-fetch.ts",
    "ingest:diff": "tsx scripts/ingest-diff.ts",
    "coverage:update": "tsx scripts/update-coverage.ts",
    "freshness:check": "tsx scripts/check-freshness.ts",
    "coverage:verify": "tsx scripts/verify-coverage.ts",
    "ingest:full": "npm run ingest:fetch && npm run build:db && npm run coverage:update",
    "test:contract": "echo \"No contract tests yet\" && exit 0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.4",
    "tsx": "^4.22.1",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "better-sqlite3": "^9.4.3",
    "cheerio": "^1.2.0",
    "zod": "^3.22.4"
  }
}
